{
  "name": "webassembly-ziper",
  "version": "0.1.0",
  "description": "A WebAssembly implementation of JSZip with compatible API",
  "main": "pkg/webassembly_ziper.js",
  "types": "pkg/webassembly_ziper.d.ts",
  "scripts": {
